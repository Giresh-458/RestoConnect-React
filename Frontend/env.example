## Frontend runtime configuration
# Leave VITE_API_BASE_URL empty for local same-origin proxy/Docker setups.
# Set it to your deployed backend URL for Vercel, for example:
# VITE_API_BASE_URL=https://restoconnect-api.onrender.com
VITE_API_BASE_URL=

## Local development
# Used only by Vite dev server proxy.
VITE_DEV_PROXY_TARGET=http://localhost:3000
VITE_PORT=5173

## Stripe configuration
# Get from Stripe Dashboard -> Developers -> API keys (Publishable key)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

