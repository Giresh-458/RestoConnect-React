FRONTEND_PORT=8080
MONGO_PORT=27017
REDIS_PORT=6380

# Frontend build-time env
VITE_API_BASE_URL=
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Backend runtime env
PUBLIC_API_URL=
CLIENT_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080
MONGODB_URI=mongodb://mongo:27017/restoconnect
REDIS_URL=redis://redis:6379
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=120
PERF_RUN_LABEL=docker_cache_enabled
SESSION_SECRET=change_me_session_secret
SESSION_MAX_AGE_MS=2592000000
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRY=30d
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
TRUST_PROXY=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
SMTP_SERVICE=gmail
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
STRIPE_SECRET_KEY=sk_test_your_secret_key
