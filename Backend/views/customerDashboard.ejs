<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">  <li><a href="#home">Profile</a></li>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customer Dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="/css/customer_dashboard_styles.css">
</head>
<body>
  <div class="dashboard">
    <!-- Sidebar -->
    <div class="sidebar">
      <ul>
        <li><a href="/">Home</a></li>
      
        <li><a href="#prev_order">Orders</a></li>
        <li class="logout"><a href="/logout">Logout</a></li>
      </ul>

    </div>

    <!-- Main Content -->
    <div class="content">
      <!-- Profile Section -->
      <div class="nadcuscontainer1" id="home">
        <div class="profile box">
          <div>
            <h3><%= name %></h3>
            <h4>Email: <%= email %></h4>
            <h4>Phone: <%= phone %></h4>
            <button id="editProfileBtn">Edit Profile</button>
          </div>
        </div>

        <!-- Edit Profile Form -->
        <div class="ncuseditprofileform box none" id="editProfileForm">
          <div id="cross_symbol_edit">
            <a href="#" class="close-btn-edit">&#10006;</a>
          </div>
          <h1>Edit Profile</h1>
          <form action="/customer/edit" method="post">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" value="<%= name %>" required>
            <br>
            <label for="email">Email</label>
            <input type="email" id="email" name="email" value="<%= email %>" required>
            <br>
            <label for="phone">Phone</label>
            <input type="text" id="phone" name="phone" value="<%= phone %>">
            <br>
            <label for="newPassword">New Password</label>
            <input type="password" id="newPassword" name="newPassword">
            <br>
            <label for="confirmPassword">Confirm Password</label>
            <input type="password" id="confirmPassword" name="confirmPassword">
            <br>
            <button type="submit">Save Changes</button>
          </form>
        </div>

        <!-- Previous Orders -->
        <div class="ncuspastorder box" id="prev_order">
          <div class="ncusprevdiv">
            <% prev_order.forEach(order => { %>
              <div>
                <h1><%= order.name %></h1>
                <ul>
                  <% order.items.forEach(item => { %>
                    <li><%= item %></li>
                  <% }) %>
                </ul>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Charts Section -->
        <div class="nadcusdashboards box" id="charts">
          <div class="chart-container">
            <canvas id="pichart1" width="200" height="200"></canvas>
            <ul>
              <% item_list.forEach((item, i) => { %>
                <li><%= item %> - <%= item_counts[i] %></li>
              <% }) %>
            </ul>
          </div>
          <div class="chart-container">
            <canvas id="pichart2" width="200" height="200"></canvas>
            <ul>
              <% restaurent_list.forEach((rest, i) => { %>
                <li><%= rest %> - <%= restaurent_counts[i] %></li>
              <% }) %>
            </ul>
          </div>
        </div>
        
      </div>
        <div class="cus-feedback-bottom">
    <h2>Your Feedbacks</h2>
    <% if (feedbackList && feedbackList.length > 0) { %>
      <table>
        <thead>
          <tr>
            <th>Dining Rating</th>
            <th>Loved Items</th>
            <th>Order Rating</th>
            <th>Additional Feedback</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% feedbackList.forEach(fb => { %>
            <tr>
              <td><%= fb.diningRating || 0 %> / 5</td>
              <td><%= fb.lovedItems || '-' %></td>
              <td><%= fb.orderRating || 0 %> / 5</td>
              <td><%= fb.additionalFeedback || '-' %></td>
              <td><%= fb.createdAt ? fb.createdAt.toLocaleString() : '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <p>No feedback submitted yet.</p>
    <% } %>
  </div>
    </div>
  </div>

  <!-- Feedback Section -->


  <script>
    const item_list = <%- JSON.stringify(item_list) %>;
    const item_counts = <%- JSON.stringify(item_counts) %>;
    const restaurent_list = <%- JSON.stringify(restaurent_list) %>;
    const restaurent_counts = <%- JSON.stringify(restaurent_counts) %>;
  </script>
  <script src="/js/customer_dashboard_script.js"></script>
</body>
</html>
