<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RestoConnect - Dashboard</title>
    <link rel="stylesheet" href="/css/owner_dashboard.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </head>
  <body>
    <header>
      <a href="/owner" class="backButton">Back</a>
      <h1>Owner Dashboard - <%= restaurant %></h1>
      <a href="/logout" class="logout-btn">Logout</a>
    </header>
    <main>
      <div class="dashboard-container">
        <div class="card">
          <h3>Total Orders</h3>
          <p id="totalOrders"><%= totalOrders %></p>
        </div>
        <div class="card">
          <h3>Total Customers</h3>
          <p id="totalCustomers"><%= totalCustomers %></p>
        </div>
        <div class="card">
          <h3>Total Revenue</h3>
          <p id="totalRevenue">$<%= totalRevenue.toFixed(2) %></p>
        </div>
      </div>

      <div class="charts-container">
        <div class="chart-box">
          <h3>Weekly Revenue</h3>
          <canvas id="weeklyRevenueChart"></canvas>
        </div>
        <div class="chart-box">
          <h3>Daily Revenue</h3>
          <canvas id="dailyRevenueChart"></canvas>
        </div>
      </div>






<div>
   <h3>Customer Feedbacks</h3>
<% if (feedbackList && feedbackList.length > 0) { %>
<table>
  <thead>
    <tr>
      <th>Customer</th>
      <th>Dining Rating</th>
      <th>Loved Items</th>
      <th>Order Rating</th>
      <th>Additional Feedback</th>
      <th>Date</th>
    </tr>
  </thead>
  <tbody>
    <% feedbackList.forEach(fb => { %>
    <tr>
      <td><%= fb.customerName %></td>
      <td><%= fb.diningRating %></td>
      <td><%= fb.lovedItems %></td>
      <td><%= fb.orderRating %></td>
      <td><%= fb.additionalFeedback %></td>
      <td><%= fb.createdAt.toLocaleString() %></td>
    </tr>
    <% }) %>
  </tbody>
</table>
<% } else { %>
<p>No feedback received yet.</p>
<% } %>
</div>



    </main>
    <script>
         const weeklyRevenueLabels = <%- JSON.stringify(weeklyRevenueLabels) %>;
      const weeklyRevenueValues = <%- JSON.stringify(weeklyRevenueValues) %>;
      const dailyRevenueLabels = <%- JSON.stringify(dailyRevenueLabels) %>;
      const dailyRevenueValues = <%- JSON.stringify(dailyRevenueValues) %>;
      const totalOrders = <%= totalOrders %>;
      const totalCustomers = <%= totalCustomers %>;
      const totalRevenue = <%= totalRevenue.toFixed(2) %>;
    </script>
    <script src="/js/ownerDashboard.js ">
    </script>
     <script src="/js/customer_dashboard_script.js"></script>
  </body>
</html>
