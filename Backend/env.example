## Server
NODE_ENV=development
PORT=3000
PUBLIC_API_URL=

## Frontend origins
# Single primary frontend URL
CLIENT_URL=http://localhost:5173

# Optional comma-separated list for additional allowed origins
# Example: CORS_ALLOWED_ORIGINS=http://localhost:8080,https://restoconnect.vercel.app
CORS_ALLOWED_ORIGINS=

## Database and Redis
MONGODB_URI=mongodb://127.0.0.1:27017/restoconnect
REDIS_URL=redis://127.0.0.1:6379
CACHE_ENABLED=false
PERF_RUN_LABEL=baseline_no_cache
CACHE_DEFAULT_TTL_SECONDS=120

## Auth and cookies
SESSION_SECRET=change_me_session_secret
SESSION_MAX_AGE_MS=2592000000
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRY=30d
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
TRUST_PROXY=false

## Email (required for forgot-password emails)
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
SMTP_SERVICE=gmail
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false

## Stripe (DO NOT commit real secrets)
# Get from Stripe Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Optional (for future webhook support)
# STRIPE_WEBHOOK_SECRET=whsec_...

